         <subform name="Data" layout="tb">
            <bind match="none"/>
            <subform minH="44.45mm" layout="tb" name="EventInfo">
               <bind match="none"/>
               <field name="Description" access="readOnly" minH="8.89mm" w="152.4mm">
                  <ui>
                     <textEdit multiLine="1">
                        <border presence="hidden"/>
                        <margin/>
                     </textEdit>
                  </ui>
                  <font typeface="72 Brand"/>
                  <margin topInset="1.27mm" bottomInset="1.27mm" leftInset="1.27mm" rightInset="1.27mm"/>
                  <caption reserve="38.1mm">
                     <value>
                        <text xliff:rid="6F4957B9-52F6-474E-A4B9-E90ADA403C4B">Event Description</text>
                     </value>
                  </caption>
                  <bind match="dataRef" ref="$.MusicFestival.Description"/>
                  <keep intact="contentArea"/>
               </field>
               <field name="EventDateTime" h="8.89mm" access="readOnly" minW="101.6mm">
                  <ui>
                     <dateTimeEdit>
                        <border presence="hidden"/>
                        <margin/>
                     </dateTimeEdit>
                  </ui>
                  <font typeface="72 Brand"/>
                  <margin topInset="1.27mm" bottomInset="1.27mm" leftInset="1.27mm" rightInset="1.27mm"/>
                  <caption reserve="38.1mm">
                     <value>
                        <text xliff:rid="D29397C7-F70D-420B-83F9-D5310EECC112">Event Date Time</text>
                     </value>
                  </caption>
                  <bind match="dataRef" ref="$.MusicFestival.EventDateTime">
                     <picture>datetime.full{}</picture>
                  </bind>
                  <format>
                     <picture>datetime.long{}</picture>
                  </format>
               </field>
               <field name="VisitorsFeeAmount" w="101.6mm" h="8.89mm" access="readOnly">
                  <ui>
                     <numericEdit hScrollPolicy="off">
                        <border presence="hidden"/>
                        <margin/>
                     </numericEdit>
                  </ui>
                  <font typeface="72 Brand"/>
                  <margin topInset="1.27mm" bottomInset="1.27mm" leftInset="1.27mm" rightInset="1.27mm"/>
                  <value>
                     <decimal leadDigits="6"/>
                  </value>
                  <caption reserve="38.1mm">
                     <value>
                        <text xliff:rid="2467BEF2-B56A-46A0-A149-2AD2F95214D7">Event Fee</text>
                     </value>
                  </caption>
                  <bind match="dataRef" ref="$.MusicFestival.VisitorsFeeAmount"/>
               </field>
               <field name="VisitorsFeeCurrency" w="101.6mm" h="8.89mm" access="readOnly">
